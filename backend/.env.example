NODE_ENV=development
APP_BASE_URL=http://localhost:4200
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

JWT_ACCESS_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_SECRET=replace_with_a_strong_random_secret

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_mail_user
MAIL_PASS=your_mail_password
MAIL_FROM=no-reply@example.com

ADMIN_DEFAULT_PASSWORD=replace_with_a_strong_admin_password
ALLOW_MOCK_PAYMENTS=false

# Paiement Stripe (réel)
FRONTEND_ORIGIN=http://localhost:4200
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_SUCCESS_URL=http://localhost:4200/payments/checkout?status=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4200/payments/checkout?status=cancel

# MTN MoMo Collection API
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_TARGET_ENV=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:3000/api/payments/webhook/mtn_momo
MTN_WEBHOOK_SECRET=

# Orange Money Web Payment API
ORANGE_OM_BASE_URL=https://api.orange.com
ORANGE_OM_OAUTH_PATH=/oauth/v3/token
ORANGE_OM_WEBPAY_PATH=/orange-money-webpay/dev/v1/webpayment
ORANGE_OM_STATUS_PATH=/orange-money-webpay/dev/v1/transactionstatus
ORANGE_OM_CLIENT_ID=your_orange_client_id
ORANGE_OM_CLIENT_SECRET=your_orange_client_secret
ORANGE_OM_MERCHANT_KEY=your_orange_merchant_key
ORANGE_OM_RETURN_URL=http://localhost:4200/payments/checkout?status=success
ORANGE_OM_CANCEL_URL=http://localhost:4200/payments/checkout?status=cancel
ORANGE_OM_NOTIFY_URL=http://localhost:3000/api/payments/webhook/orange_money
ORANGE_WEBHOOK_SECRET=

# Intégrations externes
CEXPRESS_PROVIDER=disabled
SMS_PROVIDER=disabled
WHATSAPP_PROVIDER=disabled

# Sécurité webhook
# false: vérifie seulement si un secret webhook est configuré
# true: exige une signature valide pour tous les webhooks
PAYMENT_WEBHOOK_STRICT=false
PAYMENT_WEBHOOK_SECRET=
